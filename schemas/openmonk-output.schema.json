{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openmonk-output",
  "title": "OpenMonk Output",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["audio", "silence", "status", "timer", "visual"]
    },
    "status": {
      "type": "string",
      "enum": [
        "Silence begins.",
        "Breath reference starts.",
        "Session complete.",
        "Returning.",
        "Paused.",
        "Stopped.",
        "Preparing."
      ]
    },
    "audioFormat": {
      "type": "string",
      "enum": ["audio/mpeg"]
    },
    "glyph": {
      "type": "string"
    },
    "timerSeconds": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
