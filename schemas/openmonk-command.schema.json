{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openmonk-command",
  "title": "OpenMonk Command",
  "type": "object",
  "required": ["command", "mode"],
  "properties": {
    "command": {
      "type": "string",
      "description": "The raw command string (e.g., '/om 5 --low --sparse --far')"
    },
    "mode": {
      "type": "string",
      "enum": ["zen", "om", "air", "ear", "mauna", "vow"]
    },
    "durationSeconds": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3600
    },
    "params": {
      "type": "object",
      "properties": {
        "density": { "type": "string", "enum": ["sparse", "regular", "dense"] },
        "distance": { "type": "string", "enum": ["near", "room", "far"] },
        "texture": { "type": "string", "enum": ["clean", "breathy", "granular", "resonant"] },
        "pitch": { "type": "string", "enum": ["low", "mid", "high", "adaptive"] },
        "stability": { "type": "string", "enum": ["stable", "wavering", "dissolving"] },
        "mood": { "type": "string", "enum": ["tired", "foggy", "soft", "overloaded", "late", "neutral"] }
      },
      "additionalProperties": false
    },
    "vowText": {
      "type": "string",
      "maxLength": 200
    }
  },
  "additionalProperties": false
}
